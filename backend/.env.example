# =============================================================================
# LiveOS — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Keys marked REQUIRED must be set. Keys marked OPTIONAL have working defaults.
#
# ── How providers work ────────────────────────────────────────────────────────
# Three components each have their own provider:
#   Chat/retrieval  → LLM_PROVIDER + CHAT_MODEL
#   Ingestion       → INGESTION_PROVIDER + INGESTION_MODEL  (defaults to LLM_* if omitted)
#   Embeddings      → EMBEDDING_PROVIDER + EMBEDDING_MODEL
#
# CHAT_MODEL / INGESTION_MODEL / EMBEDDING_MODEL are provider-agnostic — set the
# model name once and it works regardless of which provider is active.
# If you omit them the provider-specific fallback keys are used instead.
#
# Supported LLM_PROVIDER values:
#   "local"      — any OpenAI-compatible server (LM Studio, vLLM, llama.cpp, etc.)
#   "ollama"     — Ollama (also OpenAI-compatible, kept as a distinct alias)
#   "openai"     — OpenAI API
#   "gemini"     — Google Gemini API
#   "anthropic"  — Anthropic Claude API
#   "huggingface"— HuggingFace Inference API
# =============================================================================


# =============================================================================
# QUICK-START EXAMPLES  (uncomment ONE block, delete the rest)
# =============================================================================

# ── Option A: All local via LM Studio ────────────────────────────────────────
# Requires LM Studio running with "Local Server" enabled on port 1234.
#
# LLM_PROVIDER=local
# LLM_BASE_URL=http://127.0.0.1:1234
# LLM_API_KEY=lm-studio
# CHAT_MODEL=google/gemma-4-e4b
#
# INGESTION_MODEL=google/gemma-4-e4b   # can be a smaller/faster model
#
# EMBEDDING_PROVIDER=local
# EMBEDDING_BASE_URL=http://127.0.0.1:1234
# EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b

# ── Option B: All local via Ollama ────────────────────────────────────────────
# Requires Ollama running on port 11434.
#
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://127.0.0.1:11434
# LLM_API_KEY=ollama
# CHAT_MODEL=gemma3:4b
#
# INGESTION_MODEL=gemma3:4b
#
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_BASE_URL=http://127.0.0.1:11434
# EMBEDDING_MODEL=qwen3-embedding:0.6b

# ── Option C: Google Gemini for chat, local for ingestion ─────────────────────
# Good balance: fast cloud chat + private local extraction.
#
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...               # https://aistudio.google.com/app/apikey
# CHAT_MODEL=gemini-2.5-pro
#
# INGESTION_PROVIDER=local
# INGESTION_BASE_URL=http://127.0.0.1:1234
# INGESTION_API_KEY=lm-studio
# INGESTION_MODEL=google/gemma-4-e4b
#
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_BASE_URL=http://127.0.0.1:11434
# EMBEDDING_MODEL=qwen3-embedding:0.6b

# ── Option D: OpenAI for everything ───────────────────────────────────────────
#
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-...           # https://platform.openai.com/api-keys
# CHAT_MODEL=gpt-4o
# OPENAI_MODEL_REASONING=o1-mini       # used by reason() calls only
#
# INGESTION_MODEL=gpt-4o               # or omit to share CHAT_MODEL via OPENAI_MODEL
#
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ── Option E: Anthropic Claude for everything ─────────────────────────────────
#
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...         # https://console.anthropic.com/
# CHAT_MODEL=claude-opus-4-5
#
# INGESTION_MODEL=claude-haiku-3-5     # cheaper model for bulk extraction
#
# EMBEDDING_PROVIDER=ollama            # Anthropic has no embedding API — use local
# EMBEDDING_BASE_URL=http://127.0.0.1:11434
# EMBEDDING_MODEL=qwen3-embedding:0.6b


# =============================================================================
# FULL REFERENCE — every supported key with its default
# =============================================================================

# -----------------------------------------------------------------------------
# EXTERNAL API KEYS  (REQUIRED if you use those providers or features)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# HUGGINGFACE_API_KEY=hf_...
TAVILY_API_KEY=                        # Web search fallback — https://app.tavily.com

# -----------------------------------------------------------------------------
# CHAT / RETRIEVAL LLM
# -----------------------------------------------------------------------------
LLM_PROVIDER=local                     # local | ollama | openai | gemini | anthropic | huggingface

# Local / OpenAI-compatible server settings (used when LLM_PROVIDER=local or ollama)
LLM_BASE_URL=http://127.0.0.1:1234    # Ollama: http://127.0.0.1:11434
LLM_API_KEY=lm-studio                 # Ollama: "ollama"
LLM_KEEP_ALIVE=10m                    # How long to keep model loaded between requests
LLM_RESPONSE_FORMAT=text              # "text" or "json_object" — use "text" for LM Studio

# Provider-agnostic model key — set this and it works for any LLM_PROVIDER
CHAT_MODEL=                           # e.g. gemini-2.5-pro / gpt-4o / claude-opus-4-5 / gemma3:4b

# Provider-specific fallback keys (used only when CHAT_MODEL is not set)
# LLM_MODEL=google/gemma-4-e4b        # local / ollama providers
# GEMINI_MODEL=gemini-2.5-pro
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_REASONING=o1-mini      # used by reason() calls
# ANTHROPIC_MODEL=claude-opus-4-5
# HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Optional fallback provider if primary fails
# LLM_FALLBACK_PROVIDER=

# -----------------------------------------------------------------------------
# INGESTION LLM  (extraction, entity reasoning, image captioning)
# -----------------------------------------------------------------------------
# Leave all INGESTION_* blank to share the main LLM settings above.
# Set any of these to route ingestion to a different provider or model.

INGESTION_PROVIDER=                    # e.g. "local" — defaults to LLM_PROVIDER if blank
INGESTION_BASE_URL=                    # defaults to LLM_BASE_URL if blank
INGESTION_API_KEY=                     # defaults to LLM_API_KEY if blank

# Provider-agnostic model key — same idea as CHAT_MODEL
INGESTION_MODEL=                       # e.g. google/gemma-4-e4b / gemini-2.0-flash / gpt-4o-mini

# Provider-specific fallback keys (used only when INGESTION_MODEL is not set)
# INGESTION_LLM_MODEL=google/gemma-4-e4b   # local / ollama providers
# INGESTION_GEMINI_MODEL=gemini-2.0-flash  # Gemini provider

# Concurrency: how many parallel LLM calls during ingestion (default 2)
# Increase for cloud providers or multi-GPU local setups.
# INGESTION_AGENT_CONCURRENCY=4

# -----------------------------------------------------------------------------
# EMBEDDINGS
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=ollama              # local | ollama | openai — "local" = any OpenAI-compatible server
EMBEDDING_BASE_URL=http://127.0.0.1:11434  # LM Studio: http://127.0.0.1:1234
EMBEDDING_API_KEY=ollama               # LM Studio: "lm-studio"
EMBEDDING_MODEL=qwen3-embedding:0.6b  # LM Studio: text-embedding-qwen3-embedding-0.6b
EMBEDDING_DIMENSIONS=1024             # Must match the model's actual output dimensions

# -----------------------------------------------------------------------------
# DATABASES
# -----------------------------------------------------------------------------
# PostgreSQL (REQUIRED — used for notes, users, feedback)
DATABASE_TRANSACTION_POOLER_URL=postgresql://user:password@127.0.0.1:5433/liveos
DATABASE_SESSION_POOLER_URL=postgresql://user:password@127.0.0.1:5433/liveos
DATABASE_DIRECT_CONNECTION_URL=postgresql://user:password@127.0.0.1:5433/liveos

# Kuzu (embedded graph database — no server needed, path relative to backend/)
KUZU_DB_PATH=data/kuzu/kuzu_graph

# Qdrant (vector store — REQUIRED for semantic search)
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
# QDRANT_API_KEY=                      # Only needed for Qdrant Cloud

# Typesense (full-text search — REQUIRED)
TYPESENSE_HOST=127.0.0.1
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=liveos-dev-key
TYPESENSE_COLLECTION_NAME=liveos_nodes

# -----------------------------------------------------------------------------
# STORAGE  (RustFS locally, or any S3-compatible service)
# -----------------------------------------------------------------------------
BUCKET_NAME=liveos-assets
BUCKET_ACCESS_KEY_ID=rustfsadmin
BUCKET_SECRET_ACCESS_KEY=rustfsadmin
R2_ENDPOINT_URL=http://localhost:9000
FILES_URL=http://localhost:9000/liveos-assets
# BUCKET_TOKEN=                        # Cloudflare R2 only

# -----------------------------------------------------------------------------
# LOCAL ML MODELS  (downloaded on first run to MODELS_PATH)
# -----------------------------------------------------------------------------
MODELS_PATH=models                     # Relative to backend/

# Vision (image understanding / OCR)
MODEL_FLORENCE_HF=microsoft/Florence-2-large
MODEL_FLORENCE_LOCAL=florence-2-large

# Audio transcription
MODEL_WHISPER_HF=openai/whisper-large-v3-turbo
MODEL_WHISPER_LOCAL=whisper-large-v3-turbo

# Reranker (improves retrieval quality — runs locally, no API needed)
MODEL_RERANKER_LOCAL=qwen3-reranker-0.6b

# -----------------------------------------------------------------------------
# RETRIEVAL TUNING  (safe to leave at defaults)
# -----------------------------------------------------------------------------
VECTOR_SIMILARITY_THRESHOLD=0.50      # Minimum score for vector search results
VECTOR_PRE_RERANK_THRESHOLD=0.45      # Score threshold before passing to reranker
RERANKER_ENABLED=true
RERANKER_TOP_K=10                     # Candidates kept after reranking
RERANKER_SCORE_THRESHOLD=0.05         # Drop reranked candidates below this score
GRAPH_EXPAND_TOP_NEIGHBORS=10
GRAPH_EXPAND_SCORE_THRESHOLD=0
MAX_POTENTIAL_QUESTIONS=10
MAX_LOOP_ITERATIONS=10

# Web search fallback when local knowledge is insufficient
# FALLBACK_MODE=none                   # none | web (requires TAVILY_API_KEY) | self

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR | CRITICAL


# =============================================================================
# PROVIDER NOTES
# =============================================================================
#
# LOCAL (LM Studio / Ollama / vLLM / llama.cpp):
#   ✅ Free, completely private — nothing leaves your machine
#   ✅ Works offline
#   ⚠️  Requires a GPU or powerful CPU for reasonable speed
#   ⚠️  Quality depends on which open model you load
#
# GOOGLE GEMINI:
#   ✅ Excellent quality, very fast
#   ✅ 1M+ token context window
#   ✅ Free tier available (rate-limited)
#   ✅ Native structured output / JSON schema enforcement
#   ⚠️  Data sent to Google servers
#   Get key: https://aistudio.google.com/app/apikey
#
# OPENAI:
#   ✅ Top-tier quality (GPT-4o, o1)
#   ✅ Native structured outputs (gpt-4o-2024-08-06+)
#   ✅ Dedicated reasoning models (o1-mini, o3-mini)
#   ⚠️  Pay per token — can get expensive for ingestion
#   ⚠️  Data sent to OpenAI servers
#   Get key: https://platform.openai.com/api-keys
#
# ANTHROPIC CLAUDE:
#   ✅ Excellent reasoning and writing quality
#   ✅ 200k token context window
#   ⚠️  No embedding API — pair with local embeddings (Ollama)
#   ⚠️  No native structured output — uses prompt engineering (may be less reliable)
#   ⚠️  Pay per token
#   ⚠️  Data sent to Anthropic servers
#   Get key: https://console.anthropic.com/
#
# HUGGINGFACE:
#   ✅ Access to many open models via cloud API
#   ✅ Free tier available
#   ⚠️  Rate-limited on free tier; slower than dedicated providers
#   Get key: https://huggingface.co/settings/tokens
# =============================================================================
