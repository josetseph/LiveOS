# =============================================================================
# LiveOS Configuration Example
# =============================================================================
# Copy this file to .env and configure your settings

# -----------------------------------------------------------------------------
# LLM PROVIDER CONFIGURATION
# -----------------------------------------------------------------------------
# Choose your primary LLM provider: "ollama", "lm_studio", "openai", "gemini", or "anthropic"
LLM_PROVIDER=ollama

# Optional: Fallback provider if primary fails (leave empty to disable)
# LLM_FALLBACK_PROVIDER=openai

# -----------------------------------------------------------------------------
# OLLAMA (Local LLM - Default)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model (single model used across extraction/summarization/reasoning/brain)
OLLAMA_MODEL=gemma3:4b
OLLAMA_KEEP_ALIVE=-1
EMBEDDING_PROVIDER=ollama
MODEL_EMBEDDING=qwen3-embedding:0.6b
EMBEDDING_DIMENSIONS=1024
MODEL_VISION=MedAIBase/PaddleOCR-VL:0.9b

# -----------------------------------------------------------------------------
# LM STUDIO (Local LLM - OpenAI-Compatible API)
# -----------------------------------------------------------------------------
# LM Studio default local server endpoint:
# 1) Start local server in LM Studio
# 2) Confirm "OpenAI Compatible" API is enabled
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=gemma3:4b
LM_STUDIO_KEEP_ALIVE=-1
LM_STUDIO_MODEL_EMBEDDING=text-embedding-qwen3-embedding-0.6b
# Structured output response format for LM Studio extraction:
# json_object recommended for complex nested extraction schemas
LM_STUDIO_RESPONSE_FORMAT=json_object

# -----------------------------------------------------------------------------
# OPENAI (Cloud)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-2024-08-06
# OPENAI_MODEL_REASONING=o1-mini

# -----------------------------------------------------------------------------
# GOOGLE GEMINI (Cloud)
# -----------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-pro

# -----------------------------------------------------------------------------
# ANTHROPIC CLAUDE (Cloud)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/liveos

# Neo4j Graph Database
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# -----------------------------------------------------------------------------
# STORAGE CONFIGURATION (MinIO/S3)
# -----------------------------------------------------------------------------
BUCKET_NAME=liveos-assets
BUCKET_ACCESS_KEY_ID=minioadmin
BUCKET_SECRET_ACCESS_KEY=minioadmin
R2_ENDPOINT_URL=http://localhost:9000
FILES_URL=http://localhost:9000/liveos-assets

# -----------------------------------------------------------------------------
# HUGGING FACE MODELS (For local reranking, vision, etc.)
# -----------------------------------------------------------------------------
MODEL_FLORENCE_HF=microsoft/Florence-2-large
MODEL_FLORENCE_LOCAL=florence-2-large
MODEL_WHISPER_HF=openai/whisper-large-v3
MODEL_WHISPER_LOCAL=whisper-large-v3
MODEL_RERANKER_HF=tomaarsen/qwen3-reranker-0.6b-seq-cls
MODEL_RERANKING_LOCAL=qwen3-reranker-0.6b-seq-cls
MODELS_PATH=models

# -----------------------------------------------------------------------------
# PROVIDER COMPARISON & SELECTION GUIDE
# -----------------------------------------------------------------------------
# 
# OLLAMA (Recommended for Privacy & Cost):
# - ✅ Free, runs locally
# - ✅ Complete privacy (no data leaves your machine)
# - ✅ Native structured outputs support
# - ✅ Fast after model loaded
# - ⚠️ Requires local GPU/powerful CPU
# - ⚠️ Limited to open-source models
#
# OPENAI:
# - ✅ Best-in-class performance (GPT-4)
# - ✅ Native structured outputs (gpt-4o-2024-08-06+)
# - ✅ o1-mini for complex reasoning
# - ⚠️ Costs money (pay per token)
# - ⚠️ Data sent to OpenAI servers
#
# GEMINI:
# - ✅ Excellent performance
# - ✅ JSON schema enforcement
# - ✅ Large context window (1M+ tokens)
# - ✅ Free tier available
# - ⚠️ Data sent to Google servers
#
# ANTHROPIC CLAUDE:
# - ✅ Excellent performance
# - ✅ Strong safety features
# - ✅ Large context window (200k tokens)
# - ⚠️ No native structured outputs (uses prompt engineering)
# - ⚠️ Costs money
# - ⚠️ Data sent to Anthropic servers
#
# -----------------------------------------------------------------------------
