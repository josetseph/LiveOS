2026-02-27 02:20:57 | IngestionPipeline | INFO | Extraction Completed: summary='The New York Society of Model Engineers (NYSME) is a model railroad organization with a long history, starting in 1905 and incorporating as a formal society in 1926. It has moved multiple times, including to Central Park and Hoboken, NJ, building a large model railroad layout along the way. The Society was active during World War II and continues to operate today.' domain='Professional' entities=[Entity(name='New York Society of Model Engineers', type='Organization', importance=0.5, isolated_context='The New York Society of Model Engineers (NYSME) was originally incorporated in 1926 in New York City. There are published records that show the Society existed as early as 1905. In its early years, the organization moved to and from various locations throughout Manhattan.'), Entity(name='Central Park', type='Place', importance=0.5, isolated_context="AT that time it was basically a gentlemen's club of members who were interested in all types of model building. In 1926 the Society was formalized and incorporated under the laws of the State of New York. This was done so that the Society could obtain a permit to use a lake in New York City's Central Park for model motor boat races."), Entity(name='Hoboken', type='Place', importance=0.5, isolated_context='The location of the layout in the basement of the Astor Building was requested for the war effort. The dismantling was done with care, with salvaged usable materials going into scrap drives for the War effort.'), Entity(name='Lackawanna Railroad', type='Organization', importance=0.5, isolated_context='The location of the layout in the basement of the Astor Building was requested for the war effort. The dismantling was done with care, with salvaged usable materials going into scrap drives for the War effort.'), Entity(name='Delaware Water Gap', type='Place', importance=0.5, isolated_context='It was based on the Lackawanna Railroad from Hoboken to Scranton, Pa. It was magnificent; from the scale model of the Hoboken Terminal to the soaring Delaware Water Gap.')] concepts=[Concept(name='Model Building', definition='', isolated_context="AT that time it was basically a gentlemen's club of members who were interested in all types of model building."), Concept(name='Model Railroad', definition='', isolated_context="The Society was formalized and incorporated under the laws of the State of New York. This was done so that the Society could obtain a permit to use a lake in New York City's Central Park for model motor boat races. The location of the layout in the basement of the Astor Building was requested for the war effort."), Concept(name='War Effort', definition='', isolated_context='The dismantling was done with care, with salvaged usable materials going into scrap drives for the War effort. The location of the layout in the basement of the Astor Building was requested for the war effort.')] tasks=[Task(name='Move Layout', description='Moving the model railroad layout to different locations.', status='Complete', due_date=None, isolated_context="In its early years, the organization moved to and from various locations throughout Manhattan. In 1926 the Society was formalized and incorporated under the laws of the State of New York. This was done so that the Society could obtain a permit to use a lake in New York City's Central Park for model motor boat races. During WW2 many Society members were called to service in the Armed Forces. Regrettably, the largest of the layouts had to be dismantled."), Task(name='Dismantle Layout', description='Taking apart the model railroad layout.', status='Complete', due_date=None, isolated_context='The dismantling was done with care, with salvaged usable materials going into scrap drives for the War effort.')] persona_traits=[] references=[ExternalReference(title='New York Society of Model Engineers', type='Organization', content='The New York Society of Model Engineers (NYSME) was originally incorporated in 1926 in New York City.', source='User', isolated_context='')] relationships=[ExtractedRelationship(source_name='New York Society of Model Engineers', source_type='Organization', target_name='Central Park', target_type='Place', relationship_type='located_in', confidence=0.95, context="The Society was formalized and incorporated under the laws of the State of New York. This was done so that the Society could obtain a permit to use a lake in New York City's Central Park for model motor boat races."), ExtractedRelationship(source_name='New York Society of Model Engineers', source_type='Organization', target_name='Hoboken', target_type='Place', relationship_type='located_in', confidence=0.95, context='The location of the layout in the basement of the Astor Building was requested for the war effort.'), ExtractedRelationship(source_name='New York Society of Model Engineers', source_type='Organization', target_name='Lackawanna Railroad', target_type='Organization', relationship_type='based_on', confidence=0.95, context='It was based on the Lackawanna Railroad from Hoboken to Scranton, Pa.'), ExtractedRelationship(source_name='New York Society of Model Engineers', source_type='Organization', target_name='Delaware Water Gap', target_type='Place', relationship_type='located_in', confidence=0.95, context='It was magnificent; from the scale model of the Hoboken Terminal to the soaring Delaware Water Gap.')] sentiment='Neutral'
